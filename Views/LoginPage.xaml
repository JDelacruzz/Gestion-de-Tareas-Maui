<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gestion_de_Tareas.Views.LoginPage"
             Title=""
             BackgroundColor="{StaticResource FondoPagina}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <StackLayout Orientation="Vertical"
                     Spacing="0"
                     VerticalOptions="FillAndExpand">

            <!-- ======================== -->
            <!-- HEADER MORADO CON LOGO   -->
            <!-- ======================== -->
            <Grid HeightRequest="320">

                <BoxView BackgroundColor="{StaticResource ColorPrimarioOscuro}"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill"/>
                <BoxView BackgroundColor="{StaticResource ColorPrimario}"
                         Opacity="0.5"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill"/>

                <StackLayout Orientation="Vertical"
                             Spacing="12"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="20">

                    <!-- Logo -->
                    <Image Source="logo_morado_sinfondo.png"
                           HeightRequest="200"
                           WidthRequest="500"
                           HorizontalOptions="Center"/>

                    <Label Text="Listly"
                           FontFamily="EBGaramondBold"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Organizá tu día de forma simple"
                           FontFamily="EBGaramondItalic"
                           FontSize="13"
                           TextColor="{StaticResource White}"
                           Opacity="0.75"
                           HorizontalTextAlignment="Center"/>

                </StackLayout>
            </Grid>

            <!-- =============================== -->
            <!-- TARJETA FLOTANTE CON FORMULARIO -->
            <!-- =============================== -->
            <Border BackgroundColor="{StaticResource FondoCard}"
                    StrokeShape="RoundRectangle 24"
                    Stroke="{StaticResource ColorSeparador}"
                    Padding="24"
                    Margin="20,-40,20,0">

                <StackLayout Spacing="18">

                    <Label Text="Iniciar Sesión"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextoPrincipal}"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Bienvenido de vuelta 👋"
                           FontSize="13"
                           TextColor="{StaticResource TextoSecundario}"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,8"/>

                    <!-- Campo Usuario -->
                    <StackLayout Spacing="6">
                        <Label Text="Usuario"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextoPrincipal}"/>
                        <Border BackgroundColor="{StaticResource FondoEntry}"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{StaticResource ColorSeparador}"
                                Padding="12,4">
                            <Entry x:Name="EntryUsuario"
                                   Placeholder="Ingresa tu usuario"
                                   PlaceholderColor="{StaticResource TextoPlaceholder}"
                                   TextColor="{StaticResource TextoPrincipal}"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   HeightRequest="44"/>
                        </Border>
                    </StackLayout>

                    <!-- Campo Contraseña -->
                    <StackLayout Spacing="6">
                        <Label Text="Contraseña"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextoPrincipal}"/>
                        <Border BackgroundColor="{StaticResource FondoEntry}"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{StaticResource ColorSeparador}"
                                Padding="12,4">
                            <Entry x:Name="EntryPassword"
                                   Placeholder="Ingresa tu contraseña"
                                   PlaceholderColor="{StaticResource TextoPlaceholder}"
                                   TextColor="{StaticResource TextoPrincipal}"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   FontSize="14"
                                   HeightRequest="44"/>
                        </Border>
                    </StackLayout>

                    <!-- Mensaje de error -->
                    <Label x:Name="LblError"
                           Text=""
                           TextColor="Red"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           IsVisible="False"/>

                    <!-- Botón Login -->
                    <Button x:Name="BtnLogin"
                            Text="Ingresar"
                            BackgroundColor="{StaticResource ColorPrimario}"
                            TextColor="{StaticResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="52"
                            CornerRadius="14"
                            Margin="0,8,0,0"/>

                    <!-- Credenciales de prueba -->
                    <Border BackgroundColor="{StaticResource ColorTotalBg}"
                            StrokeShape="RoundRectangle 10"
                            Stroke="{StaticResource ColorPrimarioClaro}"
                            Padding="12,10">
                        <StackLayout Spacing="4">
                            <Label Text="🔑 Credenciales de prueba"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ColorPrimario}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Usuario: admin  |  Contraseña: 1234"
                                   FontSize="12"
                                   TextColor="{StaticResource TextoSecundario}"
                                   HorizontalTextAlignment="Center"/>
                        </StackLayout>
                    </Border>

                </StackLayout>
            </Border>

        </StackLayout>
    </ScrollView>

</ContentPage>
