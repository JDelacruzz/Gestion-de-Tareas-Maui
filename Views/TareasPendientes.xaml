<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gestion_de_Tareas.Views.TareasPendientes"
             Title="Total de Tareas Pendientes"
             BackgroundColor="{StaticResource FondoPagina}">

    <StackLayout Padding="16" Spacing="16">

        <Label Text="Tareas Pendientes"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="{StaticResource ColorTotal}"
               HorizontalTextAlignment="Center"
               Margin="0,16,0,0"/>

        <CollectionView x:Name="ListaTareasPendientes"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource FondoCard}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource ColorSeparador}"
                            Padding="14"
                            Margin="0,4">
                        <StackLayout Spacing="4">
                            <Label Text="{Binding Nombre}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextoPrincipal}"/>
                            <Label Text="{Binding Descripcion}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label Text="{Binding Estado}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTotal}"/>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</ContentPage>
